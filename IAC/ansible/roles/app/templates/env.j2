# ── Généré par Ansible — ne pas éditer manuellement ──

# LLM Provider (Ollama local par défaut)
OLLAMA_MODEL={{ ollama_model }}
OLLAMA_BASE_URL=http://ollama:11434
LLM_TEMPERATURE={{ llm_temperature }}

# Embedding
EMBED_MODEL={{ embed_model }}

# ChromaDB
CHROMA_PATH=/app/chroma_db

# Chunking
CHUNK_SIZE={{ chunk_size }}
CHUNK_OVERLAP={{ chunk_overlap }}

# Server
PORT={{ api_port }}
WORKERS={{ workers }}

# OpenAI (optionnel — décommenter si vous switchez le LLM)
# OPENAI_API_KEY={{ openai_api_key | default('') }}

# Anthropic (optionnel)
# ANTHROPIC_API_KEY={{ anthropic_api_key | default('') }}
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# YouTube
YOUTUBE_API_KEY={{ youtube_api_key | default('') }}
YT_DLP_JS_RUNTIMES=nodejs

ANONYMIZED_TELEMETRY=False
